<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_color">

    <!-- TELA DE JOGO DO QUIZ -->
    <LinearLayout
        android:id="@+id/layout_quiz_play"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="visible">

        <!-- Cabeçalho com Botão Voltar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:background="@color/white"
            android:elevation="4dp">

            <ImageButton
                android:id="@+id/btn_quiz_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/round_button"
                android:src="@android:drawable/ic_menu_revert"
                android:contentDescription="Voltar"
                android:tint="@color/white" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Desafio Divertido 🏆"
                android:textColor="@color/colorPrimaryDark"
                android:textSize="20sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center_horizontal">

            <!-- Indicador de Questão e Progresso -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp">

                <TextView
                    android:id="@+id/txt_question_counter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Questão 1 de 5 🎯"
                    android:textColor="@color/color_dark_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/txt_quiz_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pontos: 0"
                    android:textColor="@color/color_card_quiz_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true" />
            </RelativeLayout>

            <ProgressBar
                android:id="@+id/progress_quiz"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="12dp"
                android:layout_marginBottom="24dp"
                android:progress="20"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressTint="@color/colorPrimary" />

            <!-- Cartão da Pergunta -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white"
                app:strokeColor="#DFE6E9"
                app:strokeWidth="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="24dp">

                    <TextView
                        android:id="@+id/txt_question_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Qual é a fração geratriz da dízima periódica 0.333...?"
                        android:textColor="@color/color_dark_text"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:gravity="center" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Alternativas de Resposta -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_option_1"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_background"
                    android:text="A) 1/3"
                    android:textColor="@color/color_dark_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_option_2"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_background"
                    android:text="B) 3/10"
                    android:textColor="@color/color_dark_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_option_3"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/input_background"
                    android:text="C) 3/9"
                    android:textColor="@color/color_dark_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@null" />

                <Button
                    android:id="@+id/btn_option_4"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/input_background"
                    android:text="D) 1/9"
                    android:textColor="@color/color_dark_text"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@null" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

    <!-- TELA DE RESULTADO DO QUIZ -->
    <LinearLayout
        android:id="@+id/layout_quiz_result"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/bg_color"
        android:visibility="gone">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@color/white"
            app:strokeColor="@color/color_card_quiz_border"
            app:strokeWidth="3dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏆 Desafio Concluído!"
                    android:textColor="@color/color_card_quiz_text"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- Exibição das Estrelas Emojis -->
                <TextView
                    android:id="@+id/txt_quiz_stars"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐⭐⭐"
                    android:textSize="54sp"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/txt_quiz_result_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Você acertou 5 de 5!"
                    android:textColor="@color/color_dark_text"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/txt_quiz_congrats"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UAU! Você é um verdadeiro Super Herói da Matemática! 👑🚀"
                    android:textColor="@color/color_gray_text"
                    android:textSize="16sp"
                    android:gravity="center"
                    android:layout_marginTop="8dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Botões de Ação Final -->
        <Button
            android:id="@+id/btn_quiz_replay"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/round_button"
            android:text="Jogar Novamente 🔄"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <Button
            android:id="@+id/btn_quiz_menu"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/round_button"
            android:text="Voltar ao Menu Principal 🏠"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="@color/color_card_calc_text" />

    </LinearLayout>

</FrameLayout>
